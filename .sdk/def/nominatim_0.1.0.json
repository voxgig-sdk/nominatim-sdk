      }
    },
    "/status": {
      "get": {
        "summary": "Query the status of the server",
        "description": "Check the operational status of the Nominatim server. Returns information about the database connection and version.",
        "operationId": "status",
        "tags": [
          "Server Status"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ],
              "default": "text"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with server status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "description": "Status code (0 = OK)"
                    },
                    "message": {
                      "type": "string",
                      "description": "Status message"
                    },
                    "data_updated": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp when the database was last updated"
                    },
                    "software_version": {
                      "type": "string",
                      "description": "Nominatim software version"
                    },
                    "database_version": {
                      "type": "string",
                      "description": "Database version"
                    }
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/deletable": {
      "get": {
        "summary": "List objects that have been deleted in OSM",
        "description": "Returns a list of OSM objects that have been deleted in OpenStreetMap but are held back in Nominatim in case the deletion was accidental.",
        "operationId": "deletable",
        "tags": [
          "Administrative"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of deletable objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "place_id": {
                        "type": "integer",
                        "description": "Unique identifier for the place"
                      },
                      "osm_type": {
                        "type": "string",
                        "description": "OSM type (node, way, relation)"
                      },
                      "osm_id": {
                        "type": "integer",
                        "description": "OSM object ID"
                      },
                      "class": {
                        "type": "string",
                        "description": "Main OSM tag key"
                      },
                      "type": {
                        "type": "string",
                        "description": "Main OSM tag value"
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the object"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/polygons": {
      "get": {
        "summary": "List of broken polygons detected by Nominatim",
        "description": "Returns a list of broken polygons that have been detected by Nominatim during processing.",
        "operationId": "polygons",
        "tags": [
          "Administrative"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            }
          },
          {
            "name": "days",
            "in": "query",
            "description": "Number of days to look back for broken polygons",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 7
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of broken polygons",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "osm_type": {
                        "type": "string",
                        "description": "OSM type (way, relation)"
                      },
                      "osm_id": {
                        "type": "integer",
                        "description": "OSM object ID"
                      },
                      "class": {
                        "type": "string",
                        "description": "Main OSM tag key"
                      },
                      "type": {
                        "type": "string",
                        "description": "Main OSM tag value"
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the object"
                      },
                      "country_code": {
                        "type": "string",
                        "description": "Country code"
                      },
                      "updated": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Last update timestamp"
                      },
                      "errormessage": {
                        "type": "string",
                        "description": "Error message describing the polygon issue"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }

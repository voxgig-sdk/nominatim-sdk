{
  "openapi": "3.0.3",
  "info": {
    "title": "Nominatim API",
    "description": "The Nominatim API is a web service for searching OpenStreetMap (OSM) objects based on their name or type. It provides various endpoints for searching, reverse geocoding, address lookup, and server status inquiries, catering to different needs of developers and users.",
    "version": "5.2.0",
    "contact": {
      "name": "Nominatim Developer Community",
      "url": "https://nominatim.org"
    },
    "license": {
      "name": "Nominatim License",
      "url": "https://nominatim.org"
    }
  },
  "externalDocs": {
    "description": "Official Nominatim API Documentation",
    "url": "https://nominatim.org/release-docs/latest/api/Overview/"
  },
  "servers": [
    {
      "url": "https://nominatim.openstreetmap.org",
      "description": "Production server"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "summary": "Search OSM objects by name or type",
        "description": "Search for OpenStreetMap objects by their name or type. Returns a list of matching locations with their coordinates and details.",
        "operationId": "search",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Free-form query string to search for",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "street",
            "in": "query",
            "description": "Street name to search for (structured query)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "description": "City name to search for (structured query)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "county",
            "in": "query",
            "description": "County name to search for (structured query)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "State name to search for (structured query)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "query",
            "description": "Country name to search for (structured query)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "postalcode",
            "in": "query",
            "description": "Postal code to search for (structured query)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "jsonv2",
                "geojson",
                "geocodejson",
                "xml"
              ],
              "default": "jsonv2"
            }
          },
          {
            "name": "addressdetails",
            "in": "query",
            "description": "Include a breakdown of the address into elements",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Limit the number of returned results",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            }
          },
          {
            "name": "countrycodes",
            "in": "query",
            "description": "Limit search results to specific countries (comma-separated ISO 3166-1alpha2 codes)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "viewbox",
            "in": "query",
            "description": "Preferred area to find search results (format: x1,y1,x2,y2)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bounded",
            "in": "query",
            "description": "Restrict results to viewbox",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_geojson",
            "in": "query",
            "description": "Output geometry of results in GeoJSON format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_kml",
            "in": "query",
            "description": "Output geometry of results in KML format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_svg",
            "in": "query",
            "description": "Output geometry of results in SVG format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_text",
            "in": "query",
            "description": "Output geometry of results as WKT",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "extratags",
            "in": "query",
            "description": "Include additional information in the result if available",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "namedetails",
            "in": "query",
            "description": "Include a list of alternative names in the results",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "accept-language",
            "in": "query",
            "description": "Preferred language order for showing search results",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dedupe",
            "in": "query",
            "description": "Remove duplicate results",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "place_id": {
                        "type": "integer",
                        "description": "Unique identifier for the place"
                      },
                      "licence": {
                        "type": "string",
                        "description": "License information"
                      },
                      "osm_type": {
                        "type": "string",
                        "description": "OSM type (node, way, relation)"
                      },
                      "osm_id": {
                        "type": "integer",
                        "description": "OSM object ID"
                      },
                      "boundingbox": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "Bounding box coordinates"
                      },
                      "lat": {
                        "type": "string",
                        "description": "Latitude"
                      },
                      "lon": {
                        "type": "string",
                        "description": "Longitude"
                      },
                      "display_name": {
                        "type": "string",
                        "description": "Full comma-separated address"
                      },
                      "class": {
                        "type": "string",
                        "description": "Main OSM tag key"
                      },
                      "type": {
                        "type": "string",
                        "description": "Main OSM tag value"
                      },
                      "importance": {
                        "type": "number",
                        "description": "Computed importance rank"
                      },
                      "icon": {
                        "type": "string",
                        "description": "URL of icon representing the place"
                      },
                      "address": {
                        "type": "object",
                        "description": "Address breakdown"
                      }
                    }
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/reverse": {
      "get": {
        "summary": "Reverse geocoding - search OSM object by location",
        "description": "Generate an address from a latitude and longitude. Returns the closest matching OSM object for the given coordinates.",
        "operationId": "reverse",
        "tags": [
          "Reverse Geocoding"
        ],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "description": "Latitude",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -90,
              "maximum": 90
            }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "Longitude",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -180,
              "maximum": 180
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "jsonv2",
                "geojson",
                "geocodejson",
                "xml"
              ],
              "default": "jsonv2"
            }
          },
          {
            "name": "addressdetails",
            "in": "query",
            "description": "Include a breakdown of the address into elements",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "zoom",
            "in": "query",
            "description": "Level of detail required (0-18)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 18,
              "default": 18
            }
          },
          {
            "name": "polygon_geojson",
            "in": "query",
            "description": "Output geometry of results in GeoJSON format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_kml",
            "in": "query",
            "description": "Output geometry of results in KML format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_svg",
            "in": "query",
            "description": "Output geometry of results in SVG format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_text",
            "in": "query",
            "description": "Output geometry of results as WKT",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "extratags",
            "in": "query",
            "description": "Include additional information in the result if available",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "namedetails",
            "in": "query",
            "description": "Include a list of alternative names in the results",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "accept-language",
            "in": "query",
            "description": "Preferred language order for showing search results",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with reverse geocoding result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "place_id": {
                      "type": "integer",
                      "description": "Unique identifier for the place"
                    },
                    "licence": {
                      "type": "string",
                      "description": "License information"
                    },
                    "osm_type": {
                      "type": "string",
                      "description": "OSM type (node, way, relation)"
                    },
                    "osm_id": {
                      "type": "integer",
                      "description": "OSM object ID"
                    },
                    "lat": {
                      "type": "string",
                      "description": "Latitude"
                    },
                    "lon": {
                      "type": "string",
                      "description": "Longitude"
                    },
                    "display_name": {
                      "type": "string",
                      "description": "Full comma-separated address"
                    },
                    "address": {
                      "type": "object",
                      "description": "Address breakdown"
                    },
                    "boundingbox": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Bounding box coordinates"
                    }
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "404": {
            "description": "No result found for the given coordinates"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/lookup": {
      "get": {
        "summary": "Look up address details for OSM objects by their ID",
        "description": "Look up address details for one or more OSM objects by their OSM ID. Returns address information for the specified objects.",
        "operationId": "lookup",
        "tags": [
          "Address Lookup"
        ],
        "parameters": [
          {
            "name": "osm_ids",
            "in": "query",
            "description": "Comma-separated list of OSM IDs with type prefix (N for node, W for way, R for relation). Example: R146656,W104393803,N240109189",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "jsonv2",
                "geojson",
                "geocodejson",
                "xml"
              ],
              "default": "jsonv2"
            }
          },
          {
            "name": "addressdetails",
            "in": "query",
            "description": "Include a breakdown of the address into elements",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_geojson",
            "in": "query",
            "description": "Output geometry of results in GeoJSON format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_kml",
            "in": "query",
            "description": "Output geometry of results in KML format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_svg",
            "in": "query",
            "description": "Output geometry of results in SVG format",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "polygon_text",
            "in": "query",
            "description": "Output geometry of results as WKT",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "extratags",
            "in": "query",
            "description": "Include additional information in the result if available",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "namedetails",
            "in": "query",
            "description": "Include a list of alternative names in the results",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          },
          {
            "name": "accept-language",
            "in": "query",
            "description": "Preferred language order for showing search results",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with address details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "place_id": {
                        "type": "integer",
                        "description": "Unique identifier for the place"
                      },
                      "licence": {
                        "type": "string",
                        "description": "License information"
                      },
                      "osm_type": {
                        "type": "string",
                        "description": "OSM type (node, way, relation)"
                      },
                      "osm_id": {
                        "type": "integer",
                        "description": "OSM object ID"
                      },
                      "boundingbox": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "Bounding box coordinates"
                      },
                      "lat": {
                        "type": "string",
                        "description": "Latitude"
                      },
                      "lon": {
                        "type": "string",
                        "description": "Longitude"
                      },
                      "display_name": {
                        "type": "string",
                        "description": "Full comma-separated address"
                      },
                      "class": {
                        "type": "string",
                        "description": "Main OSM tag key"
                      },
                      "type": {
                        "type": "string",
                        "description": "Main OSM tag value"
                      },
                      "importance": {
                        "type": "number",
